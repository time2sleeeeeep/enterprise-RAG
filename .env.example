# Enterprise RAG - Environment Configuration
# Copy this file to .env and fill in the values

# DeepSeek API
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=enterprise_rag_chunks
# Milvus Quota & Rate Limiter (applied at container startup via milvus.yaml.template)
MILVUS_FLUSH_RATE_ENABLED=false
MILVUS_FLUSH_RATE_COLLECTION_MAX=-1

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3307
MYSQL_USER=rag_user
MYSQL_PASSWORD=rag_password_123
MYSQL_DATABASE=enterprise_rag

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_MEMORY=512mb
REDIS_MAX_MEMORY_POLICY=allkeys-lru

# Embedding Model
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DEVICE=cuda
EMBEDDING_BATCH_SIZE=32

# Reranker Model
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=cuda

# Retrieval Config
DENSE_TOP_K=20
SPARSE_TOP_K=20
RERANK_TOP_K=5
RRF_K=60

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000